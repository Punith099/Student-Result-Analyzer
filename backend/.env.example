# Flask Backend Configuration

# Database Configuration
DB_USER=student_analyzer
DB_PASSWORD=your_password_here
DB_DSN=localhost:1521/XEPDB1

# For Oracle Cloud Autonomous Database, use this format:
# DB_DSN=(description= (retry_count=20)(retry_delay=3)(address=(protocol=tcps)(port=1522)(host=your-host.oraclecloud.com))(connect_data=(service_name=your_service_name))(security=(ssl_server_dn_match=yes)))

# Security
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# Server Configuration
PORT=5000
HOST=0.0.0.0

# CORS Configuration (for production)
# ALLOWED_ORIGINS=https://your-frontend-domain.com

# Oracle Instant Client Path (if needed)
# ORACLE_CLIENT_LIB=/opt/oracle/instantclient_19_19

# Logging
LOG_LEVEL=INFO

# Session Configuration
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24